PORT=5175

# Personal API token from monday.com: Profile -> Admin -> API (or Developer section)
MONDAY_API_TOKEN=

# The cloudflared tunnel hostname/port pointing at localhost:8182 on the PC running QZ Tray
TUNNEL_HOST=some-name.trycloudflare.com
TUNNEL_PORT=443

# Exact printer name as QZ Tray/Windows sees it, e.g. "HPRT HT600(203dpi)"
PRINTER_NAME=

# Optional shared secret - if set, the webhook URL must be called as
# https://your-backend/print-webhook?secret=THIS_VALUE
WEBHOOK_SECRET=

# The label template JSON (same shape saved by the Vibe Label Designer)
LABEL_TEMPLATE_JSON={"widthMm":100,"heightMm":60,"rotation":0,"fields":[]}
