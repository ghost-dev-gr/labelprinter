PORT=5175

# Where settings.json is stored - point this at a persistent Coolify volume
# mount so it survives redeploys/restarts. This is the ONLY thing besides PORT
# that needs to be an env var - everything else (monday API token, webhook
# secret, tunnel host/port, printer name, label template) lives in settings.json
# itself, set via GET/POST /settings after the first deploy.
SETTINGS_DIR=/app/data
